# AgentOS environment variables
# Copy this file to .env and fill in the values you need.

# ─── Backend API (optional, for agent mode) ──────────────
VITE_API_BASE_URL=http://localhost:8000

# ─── LLM Provider API Keys (optional, stored in browser localStorage) ──────
# These are configured through the Settings UI, not through env vars.
# The app stores API keys in localStorage for direct browser-to-API calls.
# For production deployments, use a backend proxy to keep keys secure.

# If you want to pre-configure keys server-side instead:
# VITE_ANTHROPIC_API_KEY=
# VITE_OPENAI_API_KEY=
# VITE_DEEPSEEK_API_KEY=
# VITE_GOOGLE_API_KEY=
# VITE_MISTRAL_API_KEY=
# VITE_GROQ_API_KEY=

# ─── Local model servers (configured in Settings UI) ─────
# OLLAMA_BASE_URL=http://localhost:11434
# LMSTUDIO_BASE_URL=http://localhost:1234
